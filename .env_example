# ============================================================
# Agent-Harness — Example Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your values.
# .env is git-ignored and will NOT be committed.
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Search API Keys ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- PDF Parsing API Keys ---
MINERU_API_KEY=
PADDLEOCR_API_KEY=

# --- Academic Paper API Keys ---
SEMANTIC_SCHOLAR_API_KEY=

# --- Harness LLM Configuration (optional, overrides config.yaml) ---
# HARNESS_LLM_PROVIDER=openai
# HARNESS_LLM_MODEL=gpt-4o
# HARNESS_LLM_TEMPERATURE=0.7
# HARNESS_LLM_MAX_TOKENS=4096
# HARNESS_LLM_BASE_URL=

# --- Harness General ---
# HARNESS_VERBOSE=false
# HARNESS_TRACING_ENABLED=true
